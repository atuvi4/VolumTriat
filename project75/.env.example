# ==========================================================
# Project75 — variables d'entorn
# ==========================================================
# REGLA: cap clau privada amb prefix VITE_ (això s'exposaria al frontend).
# Les claus privades només les llegeixen les funcions de /api al servidor.

# --- Públic (frontend, opcional) ---
# Res necessari de moment. Open Food Facts és públic i no vol clau.
# VITE_APP_ENV=development

# --- Privat (serverless /api, Vercel → Project Settings → Environment Variables) ---
# USDA FoodData Central (gratuïta): https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Nutritionix (llenguatge natural): https://developer.nutritionix.com
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=

# OpenAI (assistent d'idees d'àpats, /api/ai-meal-suggest)
OPENAI_API_KEY=
# Opcional: model (per defecte gpt-4o-mini)
OPENAI_MODEL=

# BEDCA: sense API pública estable. S'integraria via dataset/CSV propi.

# --- Públic (frontend, prefix VITE_) ---
# Activa el botó experimental "Generar opcions PRO" (posa-ho a 1 per activar-lo)
VITE_NUTRITION_PRO=
